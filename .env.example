# RFPilot Environment Configuration
# Copy this file to .env and fill in your values

# === REQUIRED ===
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
CLAUDE_API_KEY=sk-ant-api03-your-key-here
DATABASE_URL=postgresql://rfpilot:rfpilot_secret@db:5432/rfpilot
REDIS_URL=redis://redis:6379/0

# === OPTIONAL ===
ENVIRONMENT=development
MAX_UPLOAD_MB=50

# SMTP (for email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@rfpilot.com

# Default admin account (created on first run)
ADMIN_EMAIL=admin@rfpilot.com
ADMIN_PASSWORD=changeme
ADMIN_NAME=Admin User
